rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSuperAdmin() {
      return isSignedIn() 
        && request.auth.token.email == 'mixer@materialflow.app';
    }

    // Allow reading connection test
    match /test/connection {
      allow read: if true;
    }

    // 2. Validation Blueprints (The "Anti-Update-Gap")
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'email']) 
        && data.userId == request.auth.uid
        && data.email is string
        && ( !data.keys().contains('displayName') || data.displayName is string )
        && ( !data.keys().contains('photoURL') || data.photoURL is string )
        && ( !data.keys().contains('createdAt') || data.createdAt == request.time );
    }

    function isValidScheduleEntry(data) {
      return data.keys().hasAll(['id', 'userId', 'date', 'machine', 'productCode', 'material', 'quantity'])
        && data.id is string
        && data.userId == request.auth.uid
        && data.date is string // Stored as ISO string or timestamp, but code uses Date objects which become timestamps/strings
        && data.machine is string
        && data.productCode is string
        && data.material is string
        && data.quantity is string
        && ( !data.keys().contains('note') || data.note is string )
        && ( !data.keys().contains('serverTimestamp') || data.serverTimestamp == request.time );
    }

    // Rules for Users and their subcollections
    match /users/{userId} {
      allow list: if isSuperAdmin();
      allow get: if isOwner(userId) || isSuperAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if (isOwner(userId) || isSuperAdmin()) && isValidUserProfile(incoming())
        && ( !existing().keys().contains('userId') || incoming().userId == existing().userId );
      
      match /entries/{entryId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isOwner(userId);
      }
    }
  }
}
