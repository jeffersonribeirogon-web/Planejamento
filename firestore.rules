rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() 
        && (
          request.auth.token.get('email', '').toLower() == "jefferson.ribeiro.gon@gmail.com"
          || request.auth.uid == "tDAndbHWmjNliBIg48vRuSrReaA2"
        );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints (The "Anti-Update-Gap")
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'email']) 
        && data.userId == request.auth.uid
        && data.email is string
        && ( !data.keys().contains('displayName') || data.displayName is string )
        && ( !data.keys().contains('photoURL') || data.photoURL is string )
        && ( !data.keys().contains('createdAt') || data.createdAt == request.time );
    }

    function isValidScheduleEntry(data) {
      return data.keys().hasAll(['id', 'userId', 'date', 'dateString', 'machine', 'productCode', 'material', 'quantity'])
        && data.id is string
        && data.userId is string
        && data.date is string
        && data.dateString is string
        && data.machine is string
        && data.productCode is string
        && data.material is string
        && data.quantity is string
        && ( !data.keys().contains('note') || data.note is string )
        && ( !data.keys().contains('serverTimestamp') || data.serverTimestamp == request.time );
    }

    // Rules for Users (Private profiles)
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming())
        && incoming().userId == existing().userId;
    }

    // Rules for Entries (Shared Global Space)
    match /schedule_entries/{entryId} {
      allow read, write: if true;
    }
  }
}
